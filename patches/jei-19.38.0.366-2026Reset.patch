+package mezz.jei.test;
+
+import mezz.jei.common.config.file.ConfigSerializer;
+import org.junit.jupiter.api.Assertions;
+import org.junit.jupiter.api.Test;
+
+import java.lang.reflect.Field;
+import java.util.concurrent.ConcurrentMap;
+
+public class ConfigSerializerTest {
+	@Test
+	public void saveTimesUsesConcurrentMap() throws ReflectiveOperationException {
+		Field saveTimes = ConfigSerializer.class.getDeclaredField("saveTimes");
+		saveTimes.setAccessible(true);
+		Assertions.assertInstanceOf(ConcurrentMap.class, saveTimes.get(null));
+	}
+}
